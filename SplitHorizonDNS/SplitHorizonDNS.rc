// Split-Horizon DNS Server – dialog resource
#include <winresrc.h>
#include "resource.h"

/////////////////////////////////////////////////////////////////////////////
// Dialog

IDD_MAIN DIALOGEX 0, 0, 450, 420
STYLE DS_SETFONT | DS_CENTER | WS_MINIMIZEBOX | WS_CAPTION | WS_SYSMENU
CAPTION "Split-Horizon DNS Server"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ── Add Record section ─────────────────────────────────────────────
    GROUPBOX        "Add Local DNS Record / DNS Rewrite",IDC_STATIC,5,5,440,93
    LTEXT           "Hostname:",IDC_STATIC,12,22,42,8
    EDITTEXT        IDC_EDIT_HOSTNAME,58,20,145,12,ES_AUTOHSCROLL
    LTEXT           "IP Address:",IDC_STATIC,212,22,46,8
    EDITTEXT        IDC_EDIT_IPADDRESS,260,20,115,12,ES_AUTOHSCROLL
    LTEXT           "Primary DNS:",IDC_STATIC,12,42,46,8
    EDITTEXT        IDC_EDIT_DNSSERVER,62,40,141,12,ES_AUTOHSCROLL
    LTEXT           "Secondary DNS:",IDC_STATIC,212,42,56,8
    EDITTEXT        IDC_EDIT_DNSSERVER2,272,40,103,12,ES_AUTOHSCROLL
    LTEXT           "(Upstream DNS servers – secondary used as fallback if primary fails)",IDC_STATIC,12,57,350,8
    PUSHBUTTON      "Add Record",IDC_BTN_ADD,370,70,70,14

    // ── Records list section ───────────────────────────────────────────
    GROUPBOX        "DNS Records",IDC_STATIC,5,103,440,140
    CONTROL         "",IDC_LIST_RECORDS,"SysListView32",
                    LVS_REPORT|LVS_SHOWSELALWAYS|LVS_SINGLESEL|WS_BORDER|WS_TABSTOP,
                    12,115,345,122
    PUSHBUTTON      "Remove Selected",IDC_BTN_REMOVE,363,115,76,14

    // ── Server control section ─────────────────────────────────────────
    GROUPBOX        "Server Control",IDC_STATIC,5,248,440,51
    PUSHBUTTON      "Start Server",IDC_BTN_START,12,259,58,14
    PUSHBUTTON      "Stop Server",IDC_BTN_STOP,76,259,58,14
    PUSHBUTTON      "Clear Cache",IDC_BTN_CLEAR_CACHE,140,259,58,14
    LTEXT           "Status: Stopped",IDC_STATIC_STATUS,204,261,234,10
    PUSHBUTTON      "Install as Service",IDC_BTN_INSTALL_SVC,12,277,80,14
    PUSHBUTTON      "Uninstall Service",IDC_BTN_UNINSTALL_SVC,98,277,80,14

    // ── Log section ────────────────────────────────────────────────────
    GROUPBOX        "Log",IDC_STATIC,5,304,440,110
    LISTBOX         IDC_LIST_LOG,12,315,426,93,
                    LBS_NOINTEGRALHEIGHT|WS_VSCROLL|WS_TABSTOP
END
